# Example environment variables for ZoneGuard backend
# Copy this file to `.env` and fill in secure values. DO NOT commit `.env`.

# Postgres connection, use your DB credentials and host
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL=postgresql://user:password@localhost:5432/zoneguard_db?schema=public

# JWT secret used to sign access tokens
JWT_SECRET=replace_with_a_strong_secret

# Server port
PORT=3000
# Copy this file, rename it to .env, and fill in your local passwords
DATABASE_URL="postgresql://postgres:YOUR_LOCAL_PASSWORD@localhost:5432/zoneguard_db?schema=public"
JWT_SECRET="generate_a_random_string_here"


# MORE EXAMPLES, NOT RELEVANT (YET)
# Server
PORT=5000
NODE_ENV=development

# PostgreSQL
PGHOST=localhost
PGPORT=5432
PGDATABASE=zoneguard_dev
PGUSER=postgres
PGPASSWORD=changeme
# Alternatively, a single connection string (used if DATABASE_URL is set):
# DATABASE_URL=postgresql://postgres:changeme@localhost:5432/zoneguard_dev

# Auth
JWT_SECRET=replace-with-a-long-random-string
JWT_EXPIRES_IN=1d
BCRYPT_SALT_ROUNDS=10

# Nodemailer (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM="ZoneGuard <no-reply@zoneguard.local>"

# CORS
CLIENT_ORIGIN=http://localhost:3000

# Hybrid Cloud/Local Archiving
LOCAL_ARCHIVE_PATH=./local-archive
ARCHIVE_RETENTION_YEARS=1
